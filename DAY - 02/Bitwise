package day2;

import java.util.Scanner;

public class bitwise {
    public static void main(String[] args){
        Scanner input = new Scanner(System.in);
        int a = input.nextInt();
        int b = input.nextInt();
        System.out.println(a&b);
        System.out.println(a|b);
        System.out.println(a^b);
        System.out.println(a<<2);
        System.out.println(a>>2);
    }

}
