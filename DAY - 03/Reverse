import java.util.Scanner;
public class reverse {
    public static void main(String[] args) {
        Scanner sr = new Scanner(System.in);
        int num = sr.nextInt();
        int rev=0;
        while(num!=0){
            int pop=num%10;
            rev=rev*10+pop;
            num/=10;
        }
        System.out.println(rev);
    }
}
