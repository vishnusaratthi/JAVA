package day3;

import java.util.Scanner;

public class factorial {
    public static void main(String[] args) {
        Scanner sr = new Scanner(System.in);
        int num=sr.nextInt();
        int fact=1;
        for(int i=1;i<=num;i++){
            fact*=i;
        }
        System.out.println("factorial =" +fact);
    }
}
