package day3;

import java.util.Scanner;

public class forloop {
    public static void main(String[] arge) {
        Scanner p = new Scanner(System.in);
        int n=p.nextInt();
        int sum=0;
        for(int i=1;i<=n;i++){
            sum+=i;
        }
        System.out.println(sum);
    }
}
