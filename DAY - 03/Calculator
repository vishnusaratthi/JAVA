package day3;
import java.util.Scanner;
public class calculator {
    public static void main(String[] args) {
        Scanner sr = new Scanner(System.in);
        int a=sr.nextInt();
        int b=sr.nextInt();
        String m=sr.next();
        switch(m){
            case"+":
                System.out.println(a+b);
                break;
            case"-":
                System.out.println(a-b);
                break;
            case"*":
                System.out.println(a*b);
                break;
            case"/":
                System.out.println(a/b);
                break;
            case"%":
                System.out.println(a%b);
                break;
            default:
                System.out.println("Invalid input");
                break;


        }
    }
}
